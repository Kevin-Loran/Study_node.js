<%- include('includes/head') %>
<%- include('includes/nav') %>

<div class="container">
  <div class="row justify-content-center">
    
    <div class="col-lg-8 my-5">
      <h1 class="display-4 text-center">login</h1>
      <p class="text-center lead">faça seu login ou cadastro:</p>

      <div class="row">
        <div class="col-md-6 px-4">
          <h4>criar conta ou entrar</h4>

          <form action="/login/register" method="post">
            <input type="hidden" name="_csrf" value= <%= csrfToken %>>
            <div class="form-group">
              <h4>Fazer cadastro</h4>
              <p>se voce ainda não tem uma conta, faça seu cadastro abaixo:</p>
              <label >Seu email</label>
              <input type="email" class="form-control" name="email">
            </div>
            <div class="form-group">
              <label >Sua senha</label>
              <input type="password" class="form-control" name="password">
            </div>
            <button type="submit" class="btn btn-primary">Crie sua conta</button>
          </form>
        </div>

        <div class="col-md-6">
          <h4>Fazer login</h4>
          <p>faça seu login se sua conta ja é existente:</p>
          
          <form action="/login/login" method="post">
            <input type="hidden" name="_csrf" value= <%= csrfToken %>>
            <div class="form-group">
              <h4>Fazer login(conta existente)</h4>
              <p>se voce ainda não tem uma conta</p>
              <label >Seu email</label>
              <input type="email" class="form-control" name="email">
            </div>
            <div class="form-group">
              <label >Sua senha</label>
              <input type="password" class="form-control" name="password">
            </div>
            <button type="submit" class="btn btn-primary">entrar</button>
          </form>
        </div>
      </div>

    </div>

  </div>
</div>

<%- include('includes/footer') %>
  